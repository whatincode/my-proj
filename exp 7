let sortColumn = "";
let sortOrder  = "ASC";

$(document).ready(function () {
    loadData();

    // Load Data
    function loadData(search = "") {
        $.ajax({
            url: "fetch.php",
            type: "GET",
            data: { search: search, sort: sortColumn, order: sortOrder },
            success: function (data) {
                $("#tableData").html(data);
            }
        });
    }

    // Validate Form
    function validateForm(name, email, phone) {
        const nameRegex  = /^[A-Za-z ]+$/;
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!name.match(nameRegex)) {
            showToast("Name must contain only letters", "danger");
            return false;
        }
        if (!email.match(emailRegex)) {
            showToast("Invalid email format", "danger");
            return false;
        }
        if (phone.length < 10) {
            showToast("Invalid phone number (min 10 digits)", "danger");
            return false;
        }
        return true;
    }

    // Insert Student
    $("#addStudent").click(function () {
        const name  = $("#name").val().trim();
        const email = $("#email").val().trim();
        const phone = $("#phone").val().trim();

        if (name === "" || email === "" || phone === "") {
            showToast("Please fill all fields", "danger");
            return;
        }
        if (!validateForm(name, email, phone)) return;

        $.ajax({
            url: "insert.php",
            type: "POST",
            data: { name, email, phone },
            success: function (response) {
                if (response.trim() === "1") {
                    loadData();
                    $("#name").val("");
                    $("#email").val("");
                    $("#phone").val("");
                    showToast("Student added successfully", "success");
                } else {
                    showToast("Error saving data.", "danger");
                }
            }
        });
    });

    // Delete Student
    $(document).on("click", ".deleteBtn", function () {
        if (confirm("Are you sure you want to delete this student?")) {
            const id = $(this).data("id");
            $.ajax({
                url: "delete.php",
                type: "POST",
                data: { id },
                success: function () {
                    loadData();
                    showToast("Student deleted successfully", "danger");
                }
            });
        }
    });

    // Open Edit Modal
    $(document).on("click", ".editBtn", function () {
        $("#editId").val($(this).data("id"));
        $("#editName").val($(this).data("name"));
        $("#editEmail").val($(this).data("email"));
        $("#editPhone").val($(this).data("phone"));
        $("#editModal").modal("show");
    });

    // Update Student
    $("#updateStudent").click(function () {
        const id    = $("#editId").val();
        const name  = $("#editName").val();
        const email = $("#editEmail").val();
        const phone = $("#editPhone").val();
        $.ajax({
            url: "update.php",
            type: "POST",
            data: { id, name, email, phone },
            success: function () {
                $("#editModal").modal("hide");
                loadData();
                showToast("Student updated successfully", "success");
            }
        });
    });

    // Live Search
    $("#search").on("keyup", function () {
        loadData($(this).val());
    });
});

// Sort
function sortData(column) {
    if (sortColumn === column) {
        sortOrder = (sortOrder === "ASC") ? "DESC" : "ASC";
    } else {
        sortColumn = column;
        sortOrder  = "ASC";
    }
    $.ajax({
        url: "fetch.php",
        type: "GET",
        data: { search: $("#search").val(), sort: sortColumn, order: sortOrder },
        success: function (data) { $("#tableData").html(data); }
    });
}

// Toast
function showToast(message, type = "success") {
    const toastEl = document.getElementById("toastMsg");
    toastEl.className = `toast align-items-center text-bg-${type} border-0`;
    $("#toastText").text(message);
    const toast = new bootstrap.Toast(toastEl);
    toast.show();
}

