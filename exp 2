<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="description" content="HTML Basics Demonstration">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HTML All Tags Demo - Flexbox</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <h1>HTML Tags Demonstration</h1>
  <p><b>HTML</b> is used to create <i>web pages</i>.</p>
</header>

<nav>
  <a href="#lists">Lists</a>
  <a href="#table">Table</a>
  <a href="#media">Media</a>
  <a href="#form">Form</a>
</nav>

<section id="lists">
  <h2>Lists</h2>
  <h3>Unordered List</h3>
  <ul>
    <li>HTML</li>
    <li>CSS</li>
    <li>JavaScript</li>
  </ul>
  <h3>Ordered List</h3>
  <ol>
    <li>Create HTML file</li>
    <li>Add content</li>
    <li>Run in browser</li>
  </ol>
  <h3>Description List</h3>
  <dl>
    <dt>HTML</dt>
    <dd>Markup language for web pages</dd>
  </dl>
</section>

<section id="table">
  <h2>Table</h2>
  <table>
    <caption><b>Student Information</b></caption>
    <tr>
      <th>Roll No</th>
      <th>Name</th>
      <th>Branch</th>
    </tr>
    <tr>
      <td>1</td>
      <td>XYZ</td>
      <td>Computer</td>
    </tr>
  </table>
</section>

<section id="media">
  <h2>Image and Link</h2>
  <center>
    <img src="https://via.placeholder.com/200x120?text=Web+Lab" alt="Web Lab">
    <br><br>
    <a href="https://www.w3schools.com" target="_blank">Learn HTML</a>
  </center>
</section>

<section id="form">
  <h2>Form</h2>
  <form>
    <fieldset>
      <legend><b>Registration Form</b></legend>
      Name:
      <input type="text" placeholder="Enter name" required><br><br>
      Email:
      <input type="email" required><br><br>
      Password:
      <input type="password"><br><br>
      Gender:
      <input type="radio" name="gender"> Male
      <input type="radio" name="gender"> Female<br><br>
      Course:
      <select>
        <option>Computer</option>
        <option>IT</option>
        <option>AIDS</option>
      </select><br><br>
      Skills:
      <input type="checkbox"> HTML
      <input type="checkbox"> CSS
      <input type="checkbox"> JS<br><br>
      <input type="submit" value="Register">
      <input type="reset">
    </fieldset>
  </form>
</section>

<footer>
  <p>&copy; 2026 Web Programming Lab</p>
</footer>

</body>
</html>

/* General Page Styling */
body {
    font-family: Arial, sans-serif;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
    background-color: #f0f4f8;
}

/* Header */
header {
    background-color: #1e3a8a;
    color: white;
    padding: 20px;
    text-align: center;
}

/* FLEXBOX NAVIGATION */
nav {
    display: flex;
    justify-content: center;
    gap: 20px;
    background-color: #2563eb;
    padding: 10px;
}

nav a {
    color: white;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    text-decoration: underline;
}

/* Sections styled as cards */
section {
    background-color: white;
    margin: 0 20px;
    padding: 20px;
    border-radius: 8px;
}

h2 {
    color: #1e40af;
}

/* Table Styling */
table {
    margin: auto;
    border-collapse: collapse;
    width: 60%;
}

th {
    background-color: #bfdbfe;
    padding: 10px;
}

td {
    padding: 10px;
    text-align: center;
    border: 1px solid #ccc;
}

/* Image Styling */
img {
    border: 2px solid #cbd5e1;
    padding: 8px;
    border-radius: 10px;
}

/* Form Styling using Flexbox */
form {
    display: flex;
    flex-direction: column;
    align-items: center;
}

input, select {
    padding: 6px;
    margin-top: 5px;
}

input[type="submit"],
input[type="reset"] {
    padding: 8px 15px;
    margin-top: 10px;
    background-color: #2563eb;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

input[type="reset"] {
    background-color: #6b7280;
}

/* Footer */
footer {
    background-color: #1e3a8a;
    color: white;
    text-align: center;
    padding: 10px;
}
